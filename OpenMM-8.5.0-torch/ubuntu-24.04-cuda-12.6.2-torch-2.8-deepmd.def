Bootstrap: docker
From: nvidia/cuda:12.6.2-devel-ubuntu24.04

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y \
        netcdf-bin \
	    libnetcdf-dev \
	    python3-netcdf4 \
        doxygen \
        build-essential \
        flex \
        bison \
        swig \
        cmake \
        git \
        python3 \
        python3-pip \
        python3-dev \
	    python3-venv \
        wget \
        curl \
        vim \
        sudo \
        pkg-config \
        ca-certificates \
        libssl-dev \
        libffi-dev \
	    gfortran 

    python3 -m venv /opt/venv
    . /opt/venv/bin/activate
    pip install --upgrade pip setuptools wheel
    pip install numpy scipy cython parmed 

    # PyTorch
    pip install "torch==2.8.*" \
        --index-url https://download.pytorch.org/whl/cu126

    # Build and install OpenMM   
    # -----------------------------
    git clone https://github.com/openmm/openmm.git /opt/openmm-src
    cd /opt/openmm-src && mkdir build && cd build
    cmake .. \
      -DCMAKE_INSTALL_PREFIX=/opt/openmm \
      -DOPENMM_BUILD_OPENMM_ML=ON \
      -DOPENMM_BUILD_CUDA=ON \
      -DOPENMM_GENERATE_API_DOCS=OFF \
      -DOPENMM_BUILD_PYTHON_WRAPPERS=ON \
      -DBUILD_DOCS=OFF \
      -DOPENMM_BUILD_CUDA_TESTS=OFF \
      -DOPENMM_BUILD_EXAMPLES=OFF \
      -DBUILD_TESTING=OFF \
      -DPYTHON_EXECUTABLE=$(command -v python) \
      -DCMAKE_BUILD_TYPE=Release
    make -j8 &&  make install
    make PythonInstall
 
    cd /opt
    git clone https://github.com/openmm/openmm-ml.git
    cd openmm-ml
    pip install .

    cd /opt
    git clone https://github.com/deepmodeling/deepmd-kit.git deepmd-kit-src
    cd deepmd-kit-src/source
    mkdir build && cd build
    export TORCH_CUDA_ARCH_LIST="9.0;9.0a"
    cmake .. \
        -DENABLE_PYTORCH=ON \
        -DUSE_CUDA_TOOLKIT=ON \
        -DCUDAToolkit_ROOT=/usr/local/cuda \
        -DCMAKE_INSTALL_PREFIX=/opt/deepmd \
        -DCMAKE_PREFIX_PATH=/opt/venv/lib/python3.12/site-packages/torch/share/cmake/Torch
    make -j8 && make install
    cp /opt/deepmd-kit-src/source/build/op/pt/libdeepmd_op_pt.so /opt/venv/lib/python3.12/site-packages/deepmd/lib/
    cd /opt/deepmd-kit-src
    pip install .

    cd /opt
    git clone https://github.com/JingHuangLab/openmm_deepmd_plugin.git
    cd openmm_deepmd_plugin && mkdir build && cd build
    cmake .. \
        -DOPENMM_DIR=/opt/openmm \
        -DDEEPMD_DIR=/opt/deepmd
    make -j4 && make install
    make PythonInstall

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/opt/venv/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmm/lib:/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export LD_LIBRARY_PATH=/opt/deepmd/lib:$LD_LIBRARY_PATH
    export OPENMM_PLUGIN_DIR=/opt/openmm/lib/plugins

%runscript
    python - << 'EOF'
    import torch
    print("Torch:", torch.__version__)
    print("CUDA:", torch.version.cuda)
    print("CUDA available:", torch.cuda.is_available())

    import openmm
    print("OpenMM:", openmm.version.version)
EOF

